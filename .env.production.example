# =============================================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# 1C Dashboard Service - Production Settings
# =============================================================================
# WARNING: Never commit this file with real values to version control!
# Copy this file to .env and replace placeholder values with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="1C Dashboard Service"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Server Settings
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=4

# -----------------------------------------------------------------------------
# SECURITY CRITICAL: Generate strong secret keys for production!
# Use: python -c "import secrets; print(secrets.token_urlsafe(64))"
# -----------------------------------------------------------------------------
# REPLACE THIS WITH YOUR OWN SECRET KEY (minimum 64 characters)!
SECRET_KEY=your-super-secret-key-change-this-in-production-min-64-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://dashboard_user:STRONG_PASSWORD_HERE@db:5432/dashboard_prod
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# -----------------------------------------------------------------------------
# Redis Configuration (Cache & Sessions)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# AI/LLM Configuration (OpenRouter & Ollama)
# -----------------------------------------------------------------------------
# OpenRouter API for cloud-based LLM analysis (optional, fallback to Ollama)
# Get API key at: https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=meta-llama/llama-3-70b-instruct

# Ollama local LLM server (recommended for production privacy)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LLM confidence thresholds (tune for your use case)
LLM_CONFIDENCE_THRESHOLD_DICTIONARY=0.9
LLM_CONFIDENCE_THRESHOLD_HEURISTIC=0.7
LLM_CONFIDENCE_THRESHOLD_LLM=0.6

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=100
ALLOWED_EXTENSIONS=xlsx,xls,csv

# -----------------------------------------------------------------------------
# Payment Integration (YooKassa)
# Get credentials from https://yookassa.ru/my/
# -----------------------------------------------------------------------------
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_yookassa_secret_key_here
YOOKASSA_RETURN_URL=https://yourdomain.com/payment/callback
PAYMENT_WEBHOOK_SECRET=your_webhook_secret_here

# -----------------------------------------------------------------------------
# SSL/TLS Configuration
# For Let's Encrypt certificates, use certbot to generate:
# sudo certbot certonly --standalone -d yourdomain.com
# Certificates will be in /etc/letsencrypt/live/yourdomain.com/
# Or use the setup script: ./scripts/setup_ssl.sh
# -----------------------------------------------------------------------------
SSL_CERT_FILE=/app/certs/server.crt
SSL_KEY_FILE=/app/certs/server.key
SSL_DOMAIN=yourdomain.com
SSL_EMAIL=admin@yourdomain.com
SSL_ENV=prod  # Use 'dev' for self-signed, 'prod' for Let's Encrypt
DOMAIN_NAME=yourdomain.com

# -----------------------------------------------------------------------------
# Email Service Configuration (for trial notifications, password resets, etc.)
# -----------------------------------------------------------------------------
# Option 1: SMTP (recommended for production)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your_smtp_password_here
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=1C Dashboard

# Option 2: Telegram Bot (fallback or dev mode)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# Support email for user inquiries
SUPPORT_EMAIL=support@yourdomain.com

# Frontend URL for email links
FRONTEND_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------
BACKUP_SCHEDULE="0 3 * * *"  # Daily at 3 AM
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=/app/backups

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log

# -----------------------------------------------------------------------------
# Additional Production Settings
# -----------------------------------------------------------------------------
# Enable HTTPS redirect in nginx
HTTPS_REDIRECT=True
# Security headers
SECURITY_HEADERS=True
# HSTS max-age in seconds (1 year = 31536000)
HSTS_MAX_AGE=31536000
