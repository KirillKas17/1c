# =============================================================================
# 1C DASHBOARD SERVICE - PRODUCTION ENVIRONMENT
# Скопируйте этот файл в .env.production и заполните реальными значениями
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
APP_ENV=production
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=1c-dashboard.ru,www.1c-dashboard.ru

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/1c_dashboard

# Redis
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# YOOKASSA PAYMENT GATEWAY ⭐ CRITICAL FOR PRODUCTION
# -----------------------------------------------------------------------------
YOOKASSA_SHOP_ID=your-shop-id-from-yookassa
YOOKASSA_SECRET_KEY=your-secret-key-from-yookassa
YOOKASSA_RETURN_URL=https://1c-dashboard.ru/billing/success
YOOKASSA_WEBHOOK_URL=https://1c-dashboard.ru/api/v1/payments/webhook

# -----------------------------------------------------------------------------
# EMAIL SERVICE (SMTP) ⭐ CRITICAL FOR NOTIFICATIONS
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=your-email@yandex.ru
SMTP_PASSWORD=your-app-password-from-yandex
SMTP_USE_TLS=True

EMAIL_FROM=noreply@1c-dashboard.ru
EMAIL_FROM_NAME="1C Dashboard Service"
ADMIN_EMAIL=admin@1c-dashboard.ru

# -----------------------------------------------------------------------------
# SSL/HTTPS SETTINGS
# -----------------------------------------------------------------------------
USE_LETS_ENCRYPT=true
DOMAIN_NAME=1c-dashboard.ru
ADMIN_EMAIL_SSL=admin@1c-dashboard.ru

SSL_CERT_PATH=/workspace/ssl/cert.pem
SSL_KEY_PATH=/workspace/ssl/key.pem

# -----------------------------------------------------------------------------
# AI/LLM SETTINGS
# -----------------------------------------------------------------------------
# OpenRouter API (для production)
OPENROUTER_API_KEY=your-openrouter-api-key

# Или локальная Ollama
OLLAMA_BASE_URL=http://localhost:11434
USE_LOCAL_LLM=false

# -----------------------------------------------------------------------------
# MONITORING & LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true

# -----------------------------------------------------------------------------
# TRIAL SETTINGS
# -----------------------------------------------------------------------------
TRIAL_DURATION_DAYS=14
TRIAL_REPORTS_LIMIT=10
TRIAL_TEMPLATES_LIMIT=3
TRIAL_FILES_LIMIT=5
TRIAL_DAILY_REPORTS_LIMIT=3

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
CORS_ORIGINS=https://1c-dashboard.ru,https://www.1c-dashboard.ru
RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_SIZE_MB=50

# -----------------------------------------------------------------------------
# SUBSCRIPTION PRICING (RUB)
# -----------------------------------------------------------------------------
SUBSCRIPTION_BASIC_PRICE=990
SUBSCRIPTION_PRO_PRICE=2990
SUBSCRIPTION_ENTERPRISE_PRICE=9990

# -----------------------------------------------------------------------------
# AWS/S3 (OPTIONAL - для хранения файлов)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_REGION=ru-central1

# -----------------------------------------------------------------------------
# TELEGRAM BOT (FOR SUPPORT NOTIFICATIONS)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

